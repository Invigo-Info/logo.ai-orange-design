NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SMTP_EMAIL=
SMTP_PASSWORD=

# AI suggestions for the /launch onboarding (server-side only, never exposed
# to the browser). The route prefers GEMINI; if unset it tries OPENAI; if
# neither is set the onboarding falls back to its built-in static lists.

# Google Gemini (preferred)
GEMINI_API_KEY=
# Optional: override the text model (defaults to gemini-2.5-flash — cheap & fast).
GEMINI_MODEL=gemini-2.5-flash
# Optional: override the logo IMAGE model. Defaults to imagen-4.0-generate-001
# at 2K (2048x2048) for crisp, high-resolution logos. Names starting with
# "imagen" use the :predict endpoint; gemini-*-image use :generateContent.
# Use imagen-4.0-fast-generate-001 for faster (~4s) but 1024px logos.
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# Imagen resolution: "1K" or "2K" (ignored by -fast, which is 1024 only).
GEMINI_IMAGE_SIZE=2K

# OpenAI (fallback, used only if GEMINI_API_KEY is empty)
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
