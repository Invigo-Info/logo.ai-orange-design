NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SMTP_EMAIL=
SMTP_PASSWORD=

# OpenAI — powers the live AI suggestions in the /launch onboarding
# (server-side only, never exposed to the browser). If unset, the
# onboarding silently falls back to its built-in static suggestion lists.
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini — cheap & fast).
OPENAI_MODEL=gpt-4o-mini
